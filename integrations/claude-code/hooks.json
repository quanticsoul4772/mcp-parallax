{
  "_comment": "Parallax checkpoint layer - sensor plane (006). Shape verified against the Claude Code settings schema (S1, 2026-06-12): mcp_tool hooks take server + tool (bare name) + an explicit input map with ${path} substitution from the hook event JSON. Merge the 'hooks' object into your .claude/settings.json (server name must match your MCP registration, here 'parallax'). Off by default: nothing invokes the checkpoint tools until you install this. Uninstall = remove these entries; nothing else changes. All hooks fail open - a dead server never blocks your session.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "parallax",
            "tool": "checkpoint_action",
            "input": {
              "session_id": "${session_id}",
              "transcript_path": "${transcript_path}",
              "tool_name": "${tool_name}",
              "tool_input": "${tool_input}"
            },
            "timeout": 5,
            "statusMessage": "checkpoint: pre-action gate"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "parallax",
            "tool": "checkpoint_batch",
            "input": {
              "session_id": "${session_id}",
              "transcript_path": "${transcript_path}"
            },
            "timeout": 10,
            "statusMessage": "checkpoint: trajectory screen"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "parallax",
            "tool": "checkpoint_turn",
            "input": {
              "session_id": "${session_id}",
              "transcript_path": "${transcript_path}",
              "final_message": "${last_assistant_message}",
              "continuation": "${stop_hook_active}"
            },
            "timeout": 60,
            "statusMessage": "checkpoint: end-of-turn review"
          }
        ]
      }
    ]
  }
}
