{
  "$comment": "MCP tool contract for `research`. MCP-side only (no model hop for this shape - 003 D6 precedent). key_findings/disagreements/sources/stats are server-assembled; the model writes only the answer prose and gaps. Every key finding cites at least one source; every cited id resolves in sources; the grounding gate enforces this before return.",
  "name": "research",
  "description": "Offload a research question; get back a short, cited, adversarially-verified answer - not a pile of links. Runs scoped parallel searches, fetches and extracts sources, verifies every claim with independent refute-biased passes, and synthesizes a compact answer with inline citations, surfaced disagreements, and honest gaps. Depth scales rigor; budget and deadline ceilings synthesize early and say so. Every citation resolves to a source fetched during the run.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "question": { "type": "string", "minLength": 1, "description": "The research question, in natural language." },
      "depth": { "type": ["string", "null"], "enum": ["quick", "standard", "deep", null], "description": "Rigor tier; scales angles, sources, and verification votes. Default standard." },
      "focus": { "type": ["array", "null"], "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 200 }, "description": "Optional angles to bias the search toward." },
      "constraints": {
        "type": ["object", "null"],
        "properties": {
          "max_sources": { "type": ["integer", "null"], "minimum": 1, "maximum": 60, "description": "Hard cap on fetched sources; overrides the tier default." },
          "domains_allow": { "type": ["array", "null"], "maxItems": 32, "items": { "type": "string" }, "description": "Restrict fetching to these registrable domains." },
          "domains_deny": { "type": ["array", "null"], "maxItems": 32, "items": { "type": "string" }, "description": "Never fetch these domains. Absolute." },
          "budget_tokens": { "type": ["integer", "null"], "minimum": 1000, "description": "Hard token ceiling; hitting it synthesizes early with stopped_early set." },
          "deadline_ms": { "type": ["integer", "null"], "minimum": 5000, "description": "Hard wall-clock ceiling; hitting it synthesizes early with stopped_early set." }
        },
        "additionalProperties": false
      }
    },
    "required": ["question"],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "answer": { "type": "string", "description": "Executive synthesis with inline [sN] citations." },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Verification- and coverage-grounded, not vibes." },
      "key_findings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "claim": { "type": "string" },
            "support": { "type": "string", "enum": ["confirmed", "contested", "refuted", "unverified"] },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "sources": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          },
          "required": ["claim", "support", "confidence", "sources"],
          "additionalProperties": false
        }
      },
      "disagreements": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "claim": { "type": "string" },
            "positions": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "properties": {
                  "stance": { "type": "string" },
                  "sources": { "type": "array", "minItems": 1, "items": { "type": "string" } }
                },
                "required": ["stance", "sources"],
                "additionalProperties": false
              }
            }
          },
          "required": ["claim", "positions"],
          "additionalProperties": false
        }
      },
      "gaps": { "type": "array", "items": { "type": "string" }, "description": "What could not be answered, plus anything demoted by the grounding gate." },
      "sources": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "url": { "type": "string" },
            "title": { "type": "string" },
            "fetched_at": { "type": "string" },
            "credibility": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "required": ["id", "url", "title", "fetched_at", "credibility"],
          "additionalProperties": false
        },
        "description": "Identity only - never page bodies."
      },
      "stats": {
        "type": "object",
        "properties": {
          "angles": { "type": "integer", "minimum": 0 },
          "searches": { "type": "integer", "minimum": 0 },
          "sources_found": { "type": "integer", "minimum": 0 },
          "sources_fetched": { "type": "integer", "minimum": 0 },
          "claims_extracted": { "type": "integer", "minimum": 0 },
          "claims_after_dedup": { "type": "integer", "minimum": 0 },
          "claims_verified": { "type": "integer", "minimum": 0 },
          "claims_dropped": { "type": "integer", "minimum": 0 },
          "tokens": { "type": "integer", "minimum": 0 },
          "elapsed_ms": { "type": "integer", "minimum": 0 },
          "stopped_early": { "type": "boolean" },
          "stop_reason": { "type": ["string", "null"], "enum": ["budget", "deadline", "grounding", null] }
        },
        "required": ["angles", "searches", "sources_found", "sources_fetched", "claims_extracted", "claims_after_dedup", "claims_verified", "claims_dropped", "tokens", "elapsed_ms", "stopped_early", "stop_reason"],
        "additionalProperties": false
      }
    },
    "required": ["answer", "confidence", "key_findings", "disagreements", "gaps", "sources", "stats"],
    "additionalProperties": false
  }
}
